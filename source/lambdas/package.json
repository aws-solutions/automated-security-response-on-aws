{
  "name": "@amzn/asr_lambdas",
  "version": "3.1.3",
  "description": "Non-Orchestrator Lambda functions in ASR, including the Pre-processor and backend API lambdas.",
  "author": {
    "name": "Amazon Web Services",
    "url": "https://aws.amazon.com/solutions",
    "organization": true
  },
  "license": "Apache-2.0",
  "scripts": {
    "build:install": "npm ci",
    "build:clean:ts": "find . -type f -not -path \"./node_modules/*\" -not -name \"*.config.js\"  \\( -name \"*.js\" -o -name \"*.js.map\" -o -name \"*.d.ts*\" \\) -delete",
    "build:clean": "rm -rf ./node_modules && rm -rf ./coverage && npm run build:clean:ts",
    "build:ts": "./node_modules/typescript/bin/tsc",
    "watch": "tsc -w",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.ts\"",
    "test:sequential:preprocessor": "npm run build:clean:ts && export POWERTOOLS_DEV=true && jest --selectProjects 'Pre-processor Unit Tests' --runInBand --coverage --coverageDirectory=pre-processor/coverage --silent",
    "test:sequential:common": "npm run build:clean:ts && export POWERTOOLS_DEV=true && jest --selectProjects 'Common Unit Tests' --runInBand --coverage --coverageDirectory=common/coverage --silent",
    "test:sequential:api": "npm run build:clean:ts && export POWERTOOLS_DEV=true && node --experimental-vm-modules node_modules/.bin/jest --selectProjects 'API Unit Tests' --runInBand --coverage --coverageDirectory=api/coverage --silent",
    "test:sequential:synchronization": "npm run build:clean:ts && export POWERTOOLS_DEV=true && jest --selectProjects 'Synchronization Unit Tests' --runInBand --coverage --coverageDirectory=synchronization/coverage --silent"
  },
  "devDependencies": {
    "@types/aws-lambda": "8.10.159",
    "@types/node": "22.18.6",
    "@types/pako": "2.0.4",
    "aws-sdk-client-mock": "4.1.0",
    "aws-sdk-client-mock-jest": "4.1.0",
    "eslint": "10.0.1",
    "jest": "30.2.0",
    "nock": "14.0.10",
    "prettier": "3.6.2",
    "ts-jest": "29.4.6",
    "tsimportlib": "0.0.5",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@asr/data-models": "file:../data-models",
    "@aws-lambda-powertools/batch": "2.27.0",
    "@aws-lambda-powertools/commons": "2.27.0",
    "@aws-lambda-powertools/logger": "2.27.0",
    "@aws-lambda-powertools/tracer": "2.27.0",
    "@aws-sdk/client-cognito-identity-provider": "3.999.0",
    "@aws-sdk/client-dynamodb": "3.999.0",
    "@aws-sdk/client-lambda": "3.999.0",
    "@aws-sdk/client-organizations": "3.999.0",
    "@aws-sdk/client-resource-groups-tagging-api": "3.999.0",
    "@aws-sdk/client-s3": "3.999.0",
    "@aws-sdk/client-securityhub": "3.999.0",
    "@aws-sdk/client-sfn": "3.999.0",
    "@aws-sdk/client-ssm": "3.999.0",
    "@aws-sdk/lib-dynamodb": "3.999.0",
    "@aws-sdk/s3-request-presigner": "3.999.0",
    "@middy/core": "6.4.5",
    "@middy/http-cors": "6.4.5",
    "@middy/http-error-handler": "6.4.5",
    "@middy/http-header-normalizer": "6.4.5",
    "@middy/http-json-body-parser": "6.4.5",
    "@middy/http-router": "6.4.5",
    "@middy/http-urlencode-body-parser": "6.4.5",
    "@middy/http-urlencode-path-parser": "6.4.5",
    "@types/aws-lambda": "8.10.159",
    "pako": "2.1.0",
    "zod": "3.25.76"
  },
  "overrides": {
    "@mswjs/interceptors": "0.39.6",
    "type-fest": "^4.30.0",
    "minimatch@3.x": "3.1.4",
    "minimatch@9.x": "9.0.7",
    "minimatch@10.x": "10.2.3",
    "fast-xml-parser": "5.3.8"
  },
  "jestSonar": {
    "reportPath": "coverage"
  }
}
